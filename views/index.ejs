<%- include('partials/header') %>
<div class="hero-section">
  <div class="row align-items-center">
    <div class="col-lg-6 animate-in">
      <h1 class="display-4 fw-bold">Find Your Perfect <span class="text-gradient">Dream Home</span></h1>
      <p class="lead text-muted mt-3 fs-5">Search thousands of rental properties across India. Connect with owners directly and find your perfect match.</p>
      <% if (!locals.user) { %>
        <div class="mt-4 d-flex gap-3 flex-wrap">
          <a href="/register" class="btn btn-primary btn-lg px-4"><i class="bi bi-person-plus"></i> Get Started Free</a>
          <a href="/login" class="btn btn-outline-primary btn-lg px-4"><i class="bi bi-box-arrow-in-right"></i> Login</a>
        </div>
        <div class="mt-3">
          <small class="text-muted">🏠 Are you a property owner? <a href="/register" class="fw-semibold text-decoration-none">Register as Owner</a></small>
        </div>
      <% } else { %>
        <div class="mt-4">
          <a href="/<%= user.role %>/dashboard" class="btn btn-primary btn-lg px-5">
            <i class="bi bi-speedometer2"></i> Go to <%= user.role === 'owner' ? 'Owner' : 'User' %> Dashboard
          </a>
        </div>
      <% } %>
    </div>
    <div class="col-lg-6 text-center animate-in mt-4 mt-lg-0">
      <img src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=600&h=400&fit=crop" alt="Dream Home" class="img-fluid hero-img" onerror="this.style.display='none'">
    </div>
  </div>
</div>
<div class="row mt-5 text-center g-4">
  <div class="col-md-4 animate-in">
    <div class="card feature-card h-100 p-3">
      <div class="card-body">
        <div class="feature-icon purple"><i class="bi bi-search"></i></div>
        <h4 class="fw-bold mt-3">Search Properties</h4>
        <p class="text-muted">Search by city, state, or pincode to find rental homes near you with ease.</p>
      </div>
    </div>
  </div>
  <div class="col-md-4 animate-in">
    <div class="card feature-card h-100 p-3">
      <div class="card-body">
        <div class="feature-icon teal"><i class="bi bi-person-badge"></i></div>
        <h4 class="fw-bold mt-3">Connect with Owners</h4>
        <p class="text-muted">Pay a small fee to reveal owner contact details and schedule a visit instantly.</p>
      </div>
    </div>
  </div>
  <div class="col-md-4 animate-in">
    <div class="card feature-card h-100 p-3">
      <div class="card-body">
        <div class="feature-icon pink"><i class="bi bi-star-fill"></i></div>
        <h4 class="fw-bold mt-3">Premium Plans</h4>
        <p class="text-muted">Unlock unlimited searches and owner details with our affordable subscription plans.</p>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
