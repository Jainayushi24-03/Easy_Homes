<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Easy Homes - House Rent Portal</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/"><i class="bi bi-house-heart-fill"></i> Easy Homes</a>
    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto align-items-lg-center">
        <% if (locals.user) { %>
          <li class="nav-item"><a class="nav-link" href="/<%= user.role %>/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
          <% if (user.role === 'user') { %>
            <li class="nav-item"><a class="nav-link" href="/user/subscriptions"><i class="bi bi-star-fill"></i> Plans</a></li>
          <% } %>
          <li class="nav-item"><span class="nav-link text-warning fw-semibold"><i class="bi bi-person-circle"></i> <%= user.name %></span></li>
          <li class="nav-item"><a class="nav-link btn btn-light text-primary fw-semibold px-3 ms-2" href="/logout"><i class="bi bi-box-arrow-right"></i> Logout</a></li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/login"><i class="bi bi-box-arrow-in-right"></i> Login</a></li>
          <li class="nav-item"><a class="nav-link btn btn-light text-primary fw-semibold px-3 ms-2" href="/register"><i class="bi bi-person-plus"></i> Register</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
<div class="container mt-4">
