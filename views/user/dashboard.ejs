<%- include('../partials/header') %>
<div class="animate-in">
  <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
    <div>
      <h2 class="fw-bold mb-1"><i class="bi bi-search text-gradient"></i> Find Your Home</h2>
      <p class="text-muted mb-0">Search and filter rental properties</p>
    </div>
    <% if (!isSubscribed) { %>
      <a href="/user/subscriptions" class="btn btn-warning mt-2 mt-sm-0"><i class="bi bi-star-fill"></i> Subscribe for Unlimited</a>
    <% } %>
  </div>

  <% if (!isSubscribed) { %>
    <div class="alert alert-warning"><i class="bi bi-info-circle"></i> You're on the free plan. <a href="/user/subscriptions" class="fw-semibold">Subscribe</a> to unlock unlimited searches and owner details!</div>
  <% } else if (!canSearch) { %>
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> You've used all your searches. <a href="/user/subscriptions" class="fw-semibold">Upgrade your plan</a>.</div>
  <% } else if (isSubscribed) { %>
    <div class="alert alert-success"><i class="bi bi-check-circle"></i> <strong><%= plan.charAt(0).toUpperCase() + plan.slice(1) %></strong> plan — <%= searchesUsed %>/<%= searchLimit === -1 ? '∞' : searchLimit %> searches used</div>
  <% } %>
</div>

<div class="card search-card mb-4 animate-in">
  <form method="GET" action="/user/dashboard" class="row g-3">
    <div class="col-md-3 col-6">
      <label class="form-label"><i class="bi bi-building"></i> City</label>
      <input type="text" name="city" class="form-control" placeholder="e.g. mumbai" value="<%= query.city || '' %>">
    </div>
    <div class="col-md-3 col-6">
      <label class="form-label"><i class="bi bi-map"></i> State</label>
      <input type="text" name="state" class="form-control" placeholder="e.g. maharashtra" value="<%= query.state || '' %>">
    </div>
    <div class="col-md-3 col-6">
      <label class="form-label"><i class="bi bi-geo-alt"></i> Pincode</label>
      <input type="text" name="pincode" class="form-control" placeholder="e.g. 400001" value="<%= query.pincode || '' %>">
    </div>
    <div class="col-md-3 col-6">
      <label class="form-label"><i class="bi bi-sort-down"></i> Sort By</label>
      <select name="sort" class="form-select">
        <option value="">📅 Latest</option>
        <option value="price_asc" <%= query.sort === 'price_asc' ? 'selected' : '' %>>💰 Price: Low to High</option>
        <option value="price_desc" <%= query.sort === 'price_desc' ? 'selected' : '' %>>💰 Price: High to Low</option>
      </select>
    </div>
    <div class="col-md-3 col-6">
      <label class="form-label">Min Price</label>
      <input type="number" name="minPrice" class="form-control" placeholder="₹ Min" value="<%= query.minPrice || '' %>">
    </div>
    <div class="col-md-3 col-6">
      <label class="form-label">Max Price</label>
      <input type="number" name="maxPrice" class="form-control" placeholder="₹ Max" value="<%= query.maxPrice || '' %>">
    </div>
    <div class="col-md-3 col-6">
      <label class="form-label"><i class="bi bi-house-door"></i> Bedrooms</label>
      <select name="bedrooms" class="form-select">
        <option value="">Any</option>
        <option value="1" <%= query.bedrooms === '1' ? 'selected' : '' %>>1 BHK</option>
        <option value="2" <%= query.bedrooms === '2' ? 'selected' : '' %>>2 BHK</option>
        <option value="3" <%= query.bedrooms === '3' ? 'selected' : '' %>>3 BHK</option>
        <option value="4" <%= query.bedrooms === '4' ? 'selected' : '' %>>4+ BHK</option>
      </select>
    </div>
    <div class="col-md-3 col-12 d-flex align-items-end">
      <button type="submit" class="btn btn-primary w-100 py-2"><i class="bi bi-search"></i> Search Properties</button>
    </div>
  </form>
</div>

<% if (properties.length === 0) { %>
  <div class="alert alert-info animate-in"><i class="bi bi-inbox"></i> No properties found. Try changing your search filters.</div>
<% } else { %>
  <div class="row g-4">
    <% properties.forEach((p, i) => { %>
      <div class="col-md-6 col-lg-4 animate-in">
        <div class="card shadow-sm h-100">
          <img src="<%= p.images && p.images.hall || 'https://picsum.photos/seed/default/400/280' %>" class="card-img-top property-img" alt="<%= p.title %>" onerror="this.style.display='none'">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title fw-bold"><%= p.title %></h5>
            <p class="text-muted small mb-2"><i class="bi bi-geo-alt-fill text-primary"></i> <%= p.city %>, <%= p.state %> — <%= p.pincode %></p>
            <div class="d-flex gap-2 mb-2 flex-wrap">
              <span class="badge bg-primary fs-6">₹<%= p.price %>/mo</span>
              <span class="badge bg-info"><%= p.bedrooms %> BHK</span>
              <% if (p.area) { %><span class="badge bg-secondary"><%= p.area %></span><% } %>
            </div>
            <p class="text-muted small mt-2 flex-grow-1"><%= p.description.substring(0, 100) %><%= p.description.length > 100 ? '...' : '' %></p>
            <a href="/user/property/<%= p._id %>" class="btn btn-outline-primary w-100 mt-auto"><i class="bi bi-eye"></i> View Details</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
<%- include('../partials/footer') %>
