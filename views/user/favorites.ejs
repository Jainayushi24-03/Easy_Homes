<%- include('../partials/header') %>
<div class="animate-in">
  <h2 class="fw-bold mb-1"><i class="bi bi-heart-fill text-danger"></i> My Favorites</h2>
  <p class="text-muted mb-4">Properties you've saved</p>
</div>
<% if (properties.length === 0) { %>
  <div class="alert alert-info animate-in"><i class="bi bi-heart"></i> No favorites yet. Browse properties and click the heart icon to save them.</div>
<% } else { %>
  <div class="row g-4">
    <% properties.forEach((p, i) => { %>
      <div class="col-md-6 col-lg-4 animate-in">
        <div class="card shadow-sm h-100">
          <img src="<%= p.images && p.images.hall || 'https://picsum.photos/seed/default/400/280' %>" class="card-img-top property-img" alt="<%= p.title %>" onerror="this.style.display='none'">
          <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start">
              <h5 class="card-title fw-bold"><%= p.title %></h5>
              <form method="POST" action="/user/favorite/<%= p._id %>" class="ms-2">
                <button type="submit" class="btn btn-sm p-1 border-0 bg-transparent"><i class="bi bi-heart-fill text-danger fs-5"></i></button>
              </form>
            </div>
            <p class="text-muted small mb-2"><i class="bi bi-geo-alt-fill text-primary"></i> <%= p.city %>, <%= p.state %></p>
            <div class="d-flex gap-2 mb-2 flex-wrap">
              <span class="badge bg-primary fs-6">₹<%= p.price %>/mo</span>
              <span class="badge bg-info"><%= p.bedrooms %> BHK</span>
            </div>
            <a href="/user/property/<%= p._id %>" class="btn btn-outline-primary w-100 mt-auto"><i class="bi bi-eye"></i> View Details</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
<%- include('../partials/footer') %>
