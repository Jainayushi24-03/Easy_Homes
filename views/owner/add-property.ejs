<%- include('../partials/header') %>
<div class="row justify-content-center animate-in">
  <div class="col-md-10 col-lg-8">
    <div class="card shadow-lg border-0">
      <div class="card-body p-4">
        <div class="text-center mb-4">
          <div class="feature-icon purple mx-auto mb-3" style="width:60px;height:60px;font-size:1.5rem"><i class="bi bi-plus-circle"></i></div>
          <h3 class="fw-bold">List New Property</h3>
          <p class="text-muted">Fill in the details below to add your property</p>
        </div>
        <% if (locals.error) { %>
          <div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> <%= error %></div>
        <% } %>
        <form method="POST" action="/owner/add-property">
          <div class="row">
            <div class="col-md-8 mb-3">
              <label class="form-label">Property Title</label>
              <input type="text" name="title" class="form-control" placeholder="e.g. 2BHK Family Flat" required>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">Monthly Rent (₹)</label>
              <input type="number" name="price" class="form-control" placeholder="15000" required>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea name="description" class="form-control" rows="3" placeholder="Describe your property..." required></textarea>
          </div>
          <div class="row">
            <div class="col-md-3 mb-3">
              <label class="form-label">Bedrooms</label>
              <input type="number" name="bedrooms" class="form-control" value="1" min="1">
            </div>
            <div class="col-md-3 mb-3">
              <label class="form-label">Bathrooms</label>
              <input type="number" name="bathrooms" class="form-control" value="1" min="1">
            </div>
            <div class="col-md-3 mb-3">
              <label class="form-label">Area (sq ft)</label>
              <input type="text" name="area" class="form-control" placeholder="850">
            </div>
            <div class="col-md-3 mb-3">
              <label class="form-label">Reveal Price (₹)</label>
              <input type="number" name="ownerContactRevealPrice" class="form-control" value="50">
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Full Address</label>
            <input type="text" name="address" class="form-control" placeholder="Street, building..." required>
          </div>
          <div class="row">
            <div class="col-md-4 mb-3">
              <label class="form-label">City</label>
              <input type="text" name="city" class="form-control" placeholder="e.g. mumbai" required>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">State</label>
              <input type="text" name="state" class="form-control" placeholder="e.g. maharashtra" required>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">Pincode</label>
              <input type="text" name="pincode" class="form-control" placeholder="e.g. 400001" required>
            </div>
          </div>
          <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold"><i class="bi bi-plus-circle"></i> Add Property</button>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
