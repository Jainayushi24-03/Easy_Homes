PORT=3000
NODE_ENV=development
JWT_SECRET=change_this_to_a_random_secret
SESSION_SECRET=change_this_to_another_random_secret

# Render persistent disk path (leave default for local dev)
DATA_DIR=./data

# Set to "true" to re-seed 36 properties on every start (Render free tier)
SEED_ON_START=false

# Razorpay (optional — leave empty for simulated payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# For production (Render), set to your app URL
BASE_URL=http://localhost:3000
